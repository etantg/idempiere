<%-- z-tab customization --%>
.z-tab-close {
	top:var(--zk-space-md); 
	margin-right:var(--zk-space-xs);
	padding-right:var(--zk-space-4xl-plus);
}

.z-tab-button {
	width: 22px;
}

.z-tab-button [class*="z-icon-"] {
	font-weight: var(--zk-font-weight-thin);
    font-size: var(--zk-font-size-xs);
}

.z-tabbox-icon.z-tabbox-left-scroll, .z-tabbox-icon.z-tabbox-right-scroll {
	padding: 0px;
    border-radius: 0px;
    background: none;
    margin-top: var(--zk-space-xl-minus);
}

.z-tabbox-icon.z-tabbox-left-scroll .z-icon-chevron-left, .z-tabbox-icon.z-tabbox-right-scroll .z-icon-chevron-right {
	opacity: 1;
}
