:root {
	--zk-drill-space-0: var(--zk-space-0);
	--zk-drill-space-2xl: var(--zk-space-2xl);
	--zk-drill-space-4xl: var(--zk-space-4xl);
	--zk-drill-space-lg: var(--zk-space-lg);
	--zk-drill-text-color-shadow: var(--zk-text-color-shadow);
}

.drill-window-tab td {
	padding: var(--zk-drill-space-lg) var(--zk-drill-space-4xl) var(--zk-drill-space-0) var(--zk-drill-space-4xl);
}

.drill-window-field-name {
	color: var(--zk-drill-text-color-shadow);
}

.drill-window-field-header {
	color: var(--zk-drill-text-color-shadow);
}

.drill-window-field-header td {
	padding: var(--zk-drill-space-2xl) var(--zk-drill-space-4xl) var(--zk-drill-space-0) var(--zk-drill-space-4xl);
}
