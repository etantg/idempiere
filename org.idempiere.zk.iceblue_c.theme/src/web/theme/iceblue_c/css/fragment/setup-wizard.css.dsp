.tree-wsetupwizard-finished {
	background-color: var(--zk-color-status-finished);
	margin-left:var(--zk-space-5xl)
}

.tree-wsetupwizard-skipped {
	background-color: var(--zk-color-status-skipped);
	margin-left:var(--zk-space-5xl)
}

.tree-wsetupwizard-delayed {
	background-color: var(--zk-color-status-delayed);
	margin-left:var(--zk-space-5xl);
}

.tree-wsetupwizard-in-progress {
	background-color: var(--zk-color-status-in-progress);
	margin-left:var(--zk-space-5xl);
}

.tree-wsetupwizard-pending {
	background-color: var(--zk-color-status-pending);
	margin-left:var(--zk-space-5xl);
}

.tree-setupwizard-nostatus{
	margin-left:var(--zk-space-5xl);
}

.tree-wsetupwizard-finished-all {
	background-color: var(--zk-color-status-finished);
}

.progressmeter-setupwizard {
	background: var(--zk-color-status-pending) repeat-x 0 0 ;
	background-image: none;
	border: 1px solid var(--zk-color-border);
	text-align: left;
	height: var(--zk-dimension-control-sm);
	overflow: hidden;
}
.progressmeter-setupwizard-image {
	display: inline-block;
	background: var(--zk-color-status-finished);
	background-image: none;
	height: var(--zk-dimension-control-sm);
	line-height: 0;
	font-size: 0;
}
