  </copyright>

  <license url="https://www.gnu.org/licenses/old-licenses/gpl-2.0.html">
    GNU General Public License Version 2
  </license>

  <!-- Include entire core tier -->
  <includes id="org.idempiere.core.feature" version="0.0.0"/>

  <!-- Optional UI Widgets -->
  <plugin id="org.idempiere.keikai"
          download-size="0" install-size="0" version="0.0.0" unpack="false"/>
  <plugin id="org.idempiere.zk.billboard.chart"
          download-size="0" install-size="0" version="0.0.0" unpack="false"/>
  <plugin id="org.idempiere.zk.datatable"
          download-size="0" install-size="0" version="0.0.0" unpack="false"/>
  <plugin id="org.idempiere.zk.pivot"
          download-size="0" install-size="0" version="0.0.0" unpack="false"/>

  <!-- Web Services -->
  <plugin id="org.idempiere.webservices"
          download-size="0" install-size="0" version="0.0.0" unpack="false"/>
  <plugin id="org.idempiere.webservices.resources"
          download-size="0" install-size="0" version="0.0.0" unpack="false"/>

  <!-- Payment Processor -->
  <plugin id="org.adempiere.payment.processor"
          download-size="0" install-size="0" version="0.0.0" unpack="false"/>

  <!-- Replication -->
  <plugin id="org.adempiere.replication"
          download-size="0" install-size="0" version="0.0.0" unpack="false"/>
  <plugin id="org.adempiere.replication.server"
          download-size="0" install-size="0" version="0.0.0" unpack="false"/>

</feature>