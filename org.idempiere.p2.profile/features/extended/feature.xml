<?xml version="1.0" encoding="UTF-8"?>
<feature
    id="org.idempiere.extended.feature"
    label="org.idempiere.extended.feature"
    version="14.0.0.qualifier"
    provider-name="iDempiere Community">

  <description url="https://www.idempiere.org">
    Extended iDempiere installation. Extends the core with
    web services, payment processing, data replication, PIPO
    migration, SSO/OIDC, table partitioning, and all optional
    ZK UI components.
  </description>

  <copyright url="https://www.idempiere.org">
